# Хост и порт
SIRIUS_HOST=0.0.0.0
SIRIUS_PORT=8000

# Ключ шифрования для токенов (опционально, будет создан автоматически)
# TOKEN_ENCRYPTION_KEY=твой-случайный-ключ-base64

# Только для локальной разработки из исходников. На production не задавать.
# SIRIUS_PLUS_DEVELOPMENT=1

# Токен, который дал DroneBet: только для запросов Sirius Plus -> DroneBet.
# DRONEBET_OUTBOUND_TOKEN=
# Отдельный токен Sirius Plus для запросов DroneBet -> Sirius Plus.
# Сгенерируй его на сервере и передай партнёру: openssl rand -hex 32
# DRONEBET_INBOUND_TOKEN=
# Старое имя временно поддерживается только как запасной outbound-токен.
# DRONEBET_PARTNER_TOKEN=
# Не меняй без согласования с DroneBet.
# DRONEBET_API_BASE=https://dronebet.cloudpub.ru/api/partner/sirius
